# ──────────────────────────────────────────────────────────
#  BuildLedger IAM Service – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file to source control.
# ──────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
DB_URL=jdbc:mysql://localhost:3306/buildledger_iam?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=buildledger_user
DB_PASSWORD=your_db_password
DB_DRIVER=com.mysql.cj.jdbc.Driver
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false
JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# PostgreSQL alternative (uncomment if using PG):
# DB_URL=jdbc:postgresql://localhost:5432/buildledger_iam
# DB_DRIVER=org.postgresql.Driver
# JPA_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_MINIMUM_32_CHARS_SECURE_RANDOM_BASE64_KEY_HERE
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000
JWT_ISSUER=buildledger-iam

# ── Mail ──────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@buildledger.com
MAIL_PASSWORD=your_smtp_password

# ── Admin Bootstrap ───────────────────────────────────────
ADMIN_EMAIL=admin@buildledger.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_NAME=System Administrator

# ── File Storage ──────────────────────────────────────────
FILE_STORAGE_PATH=./uploads/vendor-documents

# ── External APIs ─────────────────────────────────────────
GST_API_URL=https://api.gst.gov.in/commonapi/v1.1
GST_API_KEY=your_gst_api_key

PAN_API_URL=https://api.sandbox.co.in/kyc/pan
PAN_API_KEY=your_pan_api_key

OCR_API_URL=https://api.ocr.space/parse/image
OCR_API_KEY=your_ocr_api_key

# ── Logging ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/iam-service.log
